# LKFL — Environment Variables Example
# Скопировать в .env и изменить значения для production

# ============================================================================
# Database (PostgreSQL 17)
# ============================================================================
POSTGRES_USER=lkfl
POSTGRES_PASSWORD=lkfl-dev
DB_DSN=postgresql://lkfl:lkfl-dev@postgres:5432/lkfl_platform?sslmode=disable

# ============================================================================
# Redis 7
# ============================================================================
REDIS_URL=redis://redis:6379

# ============================================================================
# Keycloak 25.0 (OIDC Identity Provider)
# ============================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ISSUER=http://localhost:8081/realms/lkfl-sdek
KEYCLOAK_CLIENT_ID=lkfl-spa
KEYCLOAK_CLIENT_SECRET=changeme-dev
KEYCLOAK_START_CMD=start-dev

# ============================================================================
# lkfl-server
# ============================================================================
SERVER_PORT=8080
LOG_LEVEL=info
JWT_SECRET=changeme-dev

# ============================================================================
# Sentry (error tracking)
# ============================================================================
SENTRY_DSN=

# ============================================================================
# Timezone
# ============================================================================
TZ=Europe/Moscow
