{
  "name": "lkfl-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui",
    "test:e2e-report": "playwright show-report",
    "test:e2e:staging": "playwright test --config=playwright.staging.config.ts",
    "test:e2e:staging-ui": "playwright test --config=playwright.staging.config.ts --ui",
    "generate-types": "openapi-typescript ./openapi/spec.yaml -o ./src/api/types.generated.ts"
  },
  "dependencies": {
    "@ukituki-ps/april-ui": "0.1.13",
    "@ukituki-ps/april-tokens": "0.1.13",
    "@mantine/core": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zustand": "^5.0.0",
    "@tanstack/react-query": "^5.50.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "vitest": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "jsdom": "^24.0.0",
    "@playwright/test": "^1.45.0",
    "openapi-typescript": "^7.0.0"
  }
}
