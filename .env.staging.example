# LKFL — Staging Environment Template
# Скопируйте в .env.staging и заполните значения
# Никогда НЕ коммитьте .env.staging с реальными значениями!

# Database
POSTGRES_USER=
POSTGRES_PASSWORD=
DB_DSN=postgresql://:@postgres:5432/lkfl_platform?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379

# Keycloak
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_ISSUER=http://keycloak:8080/realms/lkfl-sdek
KEYCLOAK_PUBLIC_URL=http://localhost:8080/realms/lkfl-sdek
KEYCLOAK_CLIENT_ID=lkfl-spa
KEYCLOAK_CLIENT_SECRET=

# Server
SERVER_PORT=8080
LOG_LEVEL=info
SENTRY_DSN=
JWT_SECRET=
RATE_LIMIT_AUTH=100
RATE_LIMIT_CATALOG=500
RATE_LIMIT_ADMIN=200

# GHCR
GHCR_REGISTRY=ghcr.io/ukituki-ps/lkfl
IMAGE_TAG=main-latest
GHCR_TOKEN=

# Deploy Worker
WEBHOOK_SECRET=
DEPLOY_TOKEN=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Timezone
TZ=Europe/Moscow
